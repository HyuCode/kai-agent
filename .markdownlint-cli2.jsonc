{
  // markdownlint-cli2 config — lints this fork's own documentation.
  // Prettier owns *formatting* (tables, blank lines, list markers); markdownlint
  // owns *content* rules. Rules that Prettier already normalizes or that fight
  // with intentional long-form docs are disabled below.
  "config": {
    "default": true,
    "MD013": false, // line-length: prose & wide tables are intentionally long
    "MD024": { "siblings_only": true }, // allow same heading text under different parents
    "MD033": false, // allow inline HTML (e.g. <!-- comments -->)
    "MD041": false // first line need not be a top-level heading
  },
  // What `pnpm run lint:md` lints (this fork's docs only). Upstream-tracked docs
  // under docs/ are excluded to avoid fork divergence / merge conflicts.
  "globs": ["docs/**/*.md", "loop/**/*.md", "CLAUDE.md"],
  "ignores": [
    "**/node_modules/**",
    ".venv/**",
    "docs/design/profile-builder.md",
    "docs/kanban/**",
    "docs/middleware/**",
    "docs/observability/**",
    "docs/security/**",
    "docs/rca-ssl-cacert-post-git-pull.md",
    "docs/plans/2026-06-09-003-fix-telegram-stream-overflow-continuations-plan.md"
  ]
}
